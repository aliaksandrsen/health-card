		"next": "16.2.7",
		"postgres": "3.4.9",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "7.77.0",
		"server-only": "0.0.1",
		"tailwind-merge": "3.6.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "4.3.0",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/bcrypt": "6.0.0",
		"@types/node": "24.13.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"@vitest/coverage-v8": "4.1.8",
		"baseline-browser-mapping": "2.10.34",
		"dotenv-cli": "11.0.0",
		"drizzle-kit": "0.31.10",
		"eslint": "9.39.4",
		"eslint-config-next": "16.2.7",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.6",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"jsdom": "29.1.1",
		"prettier": "3.8.3",
		"prettier-plugin-tailwindcss": "0.8.0",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.4",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"vitest": "4.1.8"
	},
	"name": "health-card",
	"private": true,
	"packageManager": "pnpm@11.4.0",
	"engines": {
		"node": "24.x",
		"pnpm": "11.4.0"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"env:pull:dev": "vercel env pull .env.development.local --environment=development",
		"env:pull:preview": "vercel env pull .env.preview.local --environment=preview",
		"env:pull:prod": "vercel env pull .env.production.local --environment=production",
		"preview": "VERCEL_ENV=preview dotenv -e .env.preview.local -- next start",
		"prod": "VERCEL_ENV=production dotenv -e .env.production.local -- next start",
		"build": "next build --turbopack",
		"build:vercel": "if [ \"$VERCEL_ENV\" = \"production\" ] || [ \"$VERCEL_ENV\" = \"preview\" ]; then pnpm migrate:deploy; else echo \"Skipping DB migrations for $VERCEL_ENV\"; fi && next build --turbopack",
		"start": "next start",
		"lint": "eslint .",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc -noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx scripts/seed.ts",
		"migrate:deploy": "drizzle-kit migrate"
	},
	"version": "0.1.0",
	"browserslist": {
		"production": [
			"supports es6-module",
			"not safari < 15",
			"not ios_saf < 15",
			"not firefox < 100",
			"not chrome < 100"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
