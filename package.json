	"name": "health-card",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": "24.14.1",
		"pnpm": "10.33.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/engines",
			"bcrypt",
			"prisma",
			"sharp",
			"unrs-resolver"
		]
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"preview": "dotenv -e .env.preview.local -- VERCEL_ENV=preview next start",
		"prod": "dotenv -e .env.production.local -- VERCEL_ENV=production next start",
		"build": "next build --turbopack",
		"start": "next start",
		"lint": "eslint .",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc -noEmit",
		"postinstall": "prisma generate",
		"migrate:deploy": "prisma migrate deploy"
	},
	"version": "0.1.0",
	"browserslist": {
		"production": [
			"supports es6-module",
			"not safari < 15",
			"not ios_saf < 15",
			"not firefox < 100",
			"not chrome < 100"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
